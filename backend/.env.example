# QuickCart backend environment template
# Copy to backend/.env and replace placeholder values.

# App
FLASK_ENV=development
API_PORT=5001
JWT_SECRET_KEY=your_jwt_secret_here

# Database (preferred: fill DB_* values)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blink_basket
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Optional: full connection string (overrides DB_* values when set)
DATABASE_URL=postgresql://postgres:your_db_password_here@localhost:5432/blink_basket
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECT_TIMEOUT=10

# SMS / OTP providers (optional)
REACT_APP_FAST2SMS_API_KEY=your_fast2sms_api_key_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
