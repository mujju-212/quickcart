# ==============================================
# QuickCart Backend - Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!
# ==============================================

# ==============================================
# Flask Configuration
# ==============================================
FLASK_ENV=production
SECRET_KEY=your-flask-secret-key-change-this-to-random-string

# ==============================================
# Database Configuration (Supabase PostgreSQL)
# ==============================================
# Get this from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Format: postgresql://postgres.PROJECT:[PASSWORD]@HOST:6543/postgres
DATABASE_URL=postgresql://postgres.ycwtmuclynitqursbyxd:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ==============================================
# JWT Authentication
# ==============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-to-random-string
JWT_ALGORITHM=HS256

# ==============================================
# SMS/OTP Configuration (Optional - Choose One)
# ==============================================

# Option 1: Twilio (Recommended for production)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Option 2: Fast2SMS (Indian SMS provider)
# Get from: https://www.fast2sms.com/dashboard/dev-api
REACT_APP_FAST2SMS_API_KEY=your_fast2sms_api_key

# ==============================================
# Payment Gateway (Optional - For future use)
# ==============================================
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ==============================================
# Email Configuration (Optional - For future use)
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# ==============================================
# API Configuration (Usually not needed for Render)
# ==============================================
API_HOST=0.0.0.0
API_PORT=5000

# ==============================================
# HOW TO GENERATE SECRET KEYS
# ==============================================
# Windows PowerShell:
# -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
#
# Python:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Online Generator:
# https://randomkeygen.com/ (use "CodeIgniter Encryption Keys")
# ==============================================
