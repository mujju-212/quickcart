# QuickCart root environment template
# Copy to .env and replace placeholder values.

# Frontend
# Use /api for local development (proxy in package.json forwards to backend)
REACT_APP_API_URL=/api
REACT_APP_ENV=development
REACT_APP_USE_MOCK_DATA=false

# Optional frontend integration keys
REACT_APP_FAST2SMS_API_KEY=your_fast2sms_api_key_here
MAILERSEND_API_KEY=your_mailersend_api_key_here
MAILERSEND_DOMAIN=your_mailersend_domain_here

# Optional backend fallback values
# Preferred location for backend configuration is backend/.env
FLASK_ENV=development
JWT_SECRET_KEY=your_jwt_secret_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blink_basket
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DATABASE_URL=postgresql://postgres:your_db_password_here@localhost:5432/blink_basket
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECT_TIMEOUT=10

# Optional Twilio settings
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here