{
  "expo": {
    "name": "QuickCart",
    "slug": "quickcart-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "quickcart",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFD700"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quickcart.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "QuickCart needs camera access to scan barcodes and take photos.",
        "NSPhotoLibraryUsageDescription": "QuickCart needs photo library access to set profile pictures."
      }
    },
    "android": {
      "package": "com.quickcart.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#FFD700"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image-picker",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFD700",
          "image": "./src/assets/images/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
